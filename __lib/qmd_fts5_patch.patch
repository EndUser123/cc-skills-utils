--- a/qmd/core/retrieval.py
+++ b/qmd/core/retrieval.py
@@ -79,7 +79,22 @@ def build_fts5_query(query: str) -> str:
     Returns:
         FTS5 MATCH clause
     """
-    # simplified implementation：directlyuseQuery text
-    # TODO: can add more complex query processing (OR, AND, phrase etc)
-    return query.strip()
+    # FTS5 treats `-` as NOT, `*` as prefix, `()` as grouping, `"` as phrase,
+    # `:` as column filter. A raw query like "two-levers" parses as
+    # "two NOT levers" and returns zero hits. Strip operator punctuation but
+    # preserve Unicode word characters (Latin, CJK, Cyrillic, etc.) so
+    # non-ASCII content survives. Whitespace is collapsed so empty tokens
+    # don't reach MATCH.
+    #
+    # LOCAL FORK (csf-utils) — this file is the source of truth.
+    # If qmd is reinstalled, this patch is lost; re-apply from this file.
+    # Verify:
+    #   python -c "from qmd.core.retrieval import build_fts5_query as f; assert f('two-levers')=='two levers'"
+    import re
+    cleaned = re.sub(r"[^\w\s]", " ", query)
+    cleaned = re.sub(r"\s+", " ", cleaned).strip()
+    return cleaned

